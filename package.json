{
  "name": "raices-backend",
  "version": "1.0.0",
  "scripts": {
    "build": "tsc",
    "start:dev": "nodemon --watch src --ext ts --exec ts-node src/main.ts",
    "migrate": "npx knex migrate:latest --knexfile knexfile.ts",
    "seed": "ts-node src/database/seed/seed.ts",
    "setup": "npm run migrate && npm run seed",
    "dev": "npm run setup && npm run start:dev"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@anthropic-ai/sdk": "^0.27.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "knex": "^3.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "sqlite3": "^5.1.7",
    "uuid": "^10.0.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.12.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
