{
  "name": "raices-backend",
  "version": "1.0.0",
  "scripts": {
    "build": "tsc",
    "start:dev": "nodemon --watch src --ext ts --exec ts-node src/main.ts",
    "migrate": "pnpm exec knex migrate:latest --knexfile knexfile.ts",
    "seed": "ts-node src/database/seed/seed.ts",
    "db:scan": "ts-node scripts/read-db-structure.ts",
    "setup": "pnpm run migrate && pnpm run seed",
    "dev": "pnpm run setup && pnpm run start:dev"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.5.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "firebase-admin": "^14.1.0",
    "jwks-rsa": "^4.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.12.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^10.0.0",
    "knex": "^3.3.0",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
