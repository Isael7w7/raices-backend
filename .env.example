# ═══════════════════════════════════════════════════════════════
# Raíces Backend - Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# ═══════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────
NODE_ENV=development
PORT=7000

# ── Firebase Admin SDK (Backend) ──────────────────────────────
# Get from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# Paste the ENTIRE JSON content as a single line string
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"mi-proyecto-id","private_key":"-----BEGIN RSA PRIVATE KEY-----\nMIIEpAIBAAKCAQEA... dummy key placeholder ...\n-----END RSA PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxxxx@mi-proyecto-id.iam.gserviceaccount.com"}

# Project ID from your Firebase project
FIREBASE_PROJECT_ID=mi-proyecto-id-firebase

# ── Firebase Client SDK Config (Frontend) ─────────────────────
# These values are safe to expose in the frontend bundle
# Get from: Firebase Console → Project Settings → General → Your apps → SDK setup
FIREBASE_API_KEY=AIzaSyDummyKey1234567890abcdefghijklmnop
FIREBASE_AUTH_DOMAIN=mi-proyecto-id-firebase.firebaseapp.com
FIREBASE_STORAGE_BUCKET=mi-proyecto-id-firebase.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=123456789012
# ⚠️  This is the Firebase Web App ID, NOT the Project ID.
# Do NOT reuse this value for FIREBASE_PROJECT_ID above.
FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890abcdef

# ── JWT / Auth ────────────────────────────────────────────────
# If using JWKS (Firebase Auth tokens from frontend), set this:
# JWKS_URI=https://securetoken.google.com/mi-proyecto-id-firebase/v1/keys
# If using local HS256 tokens, set this:
JWT_SECRET=super-secreto-super-seguro-para-desarrollo-12345!@

# ── Email (optional) ──────────────────────────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ── Google Cloud Storage (optional, for file uploads) ─────────
# GCS_KEY_FILE=
# GCS_BUCKET=
