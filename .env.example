# ═══════════════════════════════════════════════════════════════
# Raíces Backend - Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# ═══════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────
NODE_ENV=development
PORT=7000

# ── Firebase Admin SDK (Backend) ──────────────────────────────
# Get from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# Paste the ENTIRE JSON content as a single line string
FIREBASE_SERVICE_ACCOUNT=

# Project ID from your Firebase project (raices-499122)
FIREBASE_PROJECT_ID=raices-499122

# ── Firebase Client SDK Config (Frontend) ─────────────────────
# These values are safe to expose in the frontend bundle
# Get from: Firebase Console → Project Settings → General → Your apps → SDK setup
FIREBASE_API_KEY=AIzaSyBWG0VGwewzap1Ls3HVH-yGsNE323XYxLc
FIREBASE_AUTH_DOMAIN=raices-499122.firebaseapp.com
FIREBASE_STORAGE_BUCKET=raices-499122.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=219843566314
FIREBASE_PROJECT_ID=1:219843566314:web:e87530cd23207dd8205593

# ── JWT / Auth ────────────────────────────────────────────────
# If using JWKS (Firebase Auth tokens from frontend), set this:
# JWKS_URI=https://securetoken.google.com/raices-499122/v1/keys
# If using local HS256 tokens, set this:
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET

# ── Email (optional) ──────────────────────────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ── Google Cloud Storage (optional, for file uploads) ─────────
# GCS_KEY_FILE=
# GCS_BUCKET=
